GEMINI_API_KEY=your_gemini_api_key

# Firebase Config（從 Firebase Console 取得，見 FIREBASE_SETUP.md）
# 部署到 Vercel 時：務必在 Firebase → Authentication → Settings → Authorized domains
# 新增「網站網域」例如 asea-smart-education.vercel.app（勿把 authDomain 改成這個）
# 本機若用 http://127.0.0.1:... 或區網 IP，須在 Authorized domains 另外新增「127.0.0.1」或該 IP（與 localhost 分開）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 金流 API（Phase 3，見 FIREBASE_SETUP.md 或後端文件）
VITE_PAYMENT_API_URL=
VITE_SUBSCRIPTION_API_URL=

# 客服信件（選填，用於即時發送客服表單至管理員信箱）
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_ADMIN_EMAIL=

# 本地圖片生成（Nano Banana / generate-image API）
# 1) 專案根目錄另開終端：npx vercel dev（或 vercel dev），看終端顯示的網址埠號
# 2) 將 VERCEL_DEV_API_ORIGIN、VITE_IMAGE_GENERATION_API_URL 改成該埠（預設常為 3000）
# 3) 修改 VITE_ 變數後務必 npm run build，再 npm run preview（Vite 在 build 時寫入前端）
# 4) preview 會把 /api/* 代理到 VERCEL_DEV_API_ORIGIN，未設 VITE_IMAGE_GENERATION_API_URL 時也可用相對路徑 /api/generate-image
VERCEL_DEV_API_ORIGIN=http://localhost:3000
VITE_IMAGE_GENERATION_API_URL=http://localhost:3000/api/generate-image
