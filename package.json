{
  "name": "asea---ai-powered-smart-education-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:stem-viz-fixtures": "npx --yes tsx scripts/validate-stem-viz-fixtures.mts",
    "test:watch": "vitest",
    "postinstall": "node -e \"const fs=require('fs');const p=require('path');const pub='public';fs.mkdirSync(pub,{recursive:true});[['node_modules/@rdkit/rdkit/dist/RDKit_minimal.wasm','RDKit_minimal.wasm'],['node_modules/raphael/raphael.min.js','raphael.min.js'],['node_modules/katex/dist/katex.min.css','katex.min.css'],['node_modules/jsxgraph/distrib/jsxgraph.css','jsxgraph.css'],['node_modules/jsxgraph/distrib/jsxgraphcore.js','jsxgraphcore.js'],['node_modules/3dmol/build/3Dmol-min.js','3Dmol-min.js']].forEach(([src,dest])=>{if(fs.existsSync(src))fs.copyFileSync(src,p.join(pub,dest));});const fontsSrc=p.join('node_modules','katex','dist','fonts');const fontsDest=p.join(pub,'fonts');if(fs.existsSync(fontsSrc)){fs.mkdirSync(fontsDest,{recursive:true});fs.readdirSync(fontsSrc).forEach(f=>{fs.copyFileSync(p.join(fontsSrc,f),p.join(fontsDest,f));});}\"",
    "dev": "vite",
    "dev:api": "npx --yes vercel dev --listen 3001",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "release:web": "vite build",
    "preview:release": "vite preview",
    "serve:laptop": "npx --yes serve ../asea-laptop-test -l 4174 -s",
    "serve:laptop:preview": "vite preview --outDir ../asea-laptop-test --port 4174 --host",
    "serve:dist": "vite preview --port 4173",
    "check:release-env": "node scripts/check-release-env.mjs",
    "release:test": "vite build && vite preview",
    "cap:sync": "vite build && npx cap sync",
    "cap:android": "vite build && npx cap sync android",
    "pack:laptop": "npm run check:release-env && vite build && xcopy /E /I /Y dist ..\\asea-laptop-test",
    "pack": "npm run check:release-env && npm run cap:android && cd android && set \"JAVA_HOME=C:\\Program Files\\Microsoft\\jdk-21.0.10.7-hotspot\" && .\\gradlew.bat assembleRelease bundleRelease && copy app\\build\\outputs\\apk\\release\\app-release.apk ..\\app-release.apk /Y && cd .. && xcopy /E /I /Y dist ..\\asea-laptop-test"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@emailjs/browser": "^4.4.1",
    "@google/genai": "^1.38.0",
    "@rdkit/rdkit": "^2025.3.4-1.0.0",
    "@vercel/node": "^5.6.16",
    "3dmol": "^2.5.4",
    "acorn": "^8.16.0",
    "dompurify": "^3.3.3",
    "driver.js": "^1.4.0",
    "firebase": "^12.9.0",
    "immutable": "^3.8.3",
    "jsonrepair": "^3.13.3",
    "jsxgraph": "^1.12.2",
    "katex": "^0.16.11",
    "ketcher-core": "^3.10.0",
    "ketcher-react": "^3.10.0",
    "ketcher-standalone": "^3.10.0",
    "lightningcss": "^1.32.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.13.0",
    "miew": "^0.11.1",
    "plotly.js-dist": "2.30.0",
    "raphael": "^2.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "smiles-drawer": "^2.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.0",
    "@types/plotly.js": "^3.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-static-copy": "^3.3.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.2.4"
  }
}
